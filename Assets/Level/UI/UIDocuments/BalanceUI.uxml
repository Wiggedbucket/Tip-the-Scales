<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="BalanceBarBackground" style="flex-grow: 1; background-size: 51% 100%; background-color: rgba(176, 176, 176, 0.59); align-content: center; justify-content: center; position: absolute; width: 80%; height: 60px; align-self: center; margin-top: 10px;">
        <ui:VisualElement name="BalanceBarHolder" style="flex-grow: 1; position: absolute; width: 98%; height: 44px; background-color: rgba(0, 0, 0, 0); margin-left: 0; margin-right: 0; margin-top: 0; margin-bottom: 0; -unity-text-align: upper-left; align-self: center; flex-direction: row;">
            <ui:VisualElement name="BalanceAngelicBarFill" style="flex-grow: 1; position: relative; width: 100%; height: 44px; background-color: rgb(255, 250, 0); margin-left: 0; margin-right: 0; margin-top: 0; margin-bottom: 0; -unity-text-align: upper-left; align-self: flex-start;"/>
            <ui:VisualElement name="BalanceDemonicBarFill" style="flex-grow: 1; position: relative; width: 100%; height: 44px; background-color: rgb(199, 0, 19); margin-left: 0; margin-right: 0; margin-top: 0; margin-bottom: 0; -unity-text-align: upper-left; align-self: flex-start; flex-direction: column-reverse;"/>
        </ui:VisualElement>
        <ui:Label text="Balance: 0" name="BalancePointsLabel" style="position: absolute; width: 100%; height: 38px; -unity-text-align: middle-center; font-size: 34px; margin-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; align-content: center; color: rgb(0, 0, 0); -unity-font-style: bold;"/>
        <ui:Label text="0&#10;" name="DemonPoints" style="position: absolute; width: 96%; height: 38px; -unity-text-align: middle-right; font-size: 34px; margin-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; align-content: center; color: rgb(0, 0, 0); -unity-font-style: bold; align-self: center;"/>
        <ui:Label text="0&#10;" name="AngelPoints" style="position: absolute; width: 96%; height: 38px; -unity-text-align: middle-left; font-size: 34px; margin-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; align-content: center; color: rgb(0, 0, 0); -unity-font-style: bold; align-self: center;"/>
    </ui:VisualElement>
</ui:UXML>
