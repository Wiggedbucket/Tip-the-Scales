<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Aligner" style="flex-grow: 1; right: 0; justify-content: center;">
        <ui:VisualElement name="StyleMeter" style="flex-grow: 1; position: absolute; -unity-text-align: upper-left; height: 624px; top: auto; left: auto; right: 10px; bottom: auto; width: 436px; background-color: rgba(0, 0, 0, 0.45); border-top-width: 5px; border-bottom-width: 5px; border-left-width: 5px; border-right-width: 5px; border-top-color: rgba(0, 0, 0, 0.78); border-bottom-color: rgba(0, 0, 0, 0.78); border-left-color: rgba(0, 0, 0, 0.78); border-right-color: rgba(0, 0, 0, 0.78); scale: 0.8 0.8 0.8;">
            <ui:Label text="F" name="RankLabel" style="right: auto; position: relative; -unity-text-align: upper-center; font-size: 64px; color: rgb(161, 161, 161);"/>
            <ui:VisualElement name="StyleFeedHolder" style="flex-grow: 1;">
                <ui:VisualElement name="StyleBarBackground" style="flex-grow: 1; background-size: 51% 100%; background-color: rgba(176, 176, 176, 0.59); align-content: center; justify-content: center; position: relative; width: 100%; height: 60px;">
                    <ui:VisualElement name="FillStyleBar" style="flex-grow: 1; position: absolute; width: 98%; height: 44px; background-color: rgb(165, 0, 0); margin-left: 4px; margin-right: 0; margin-top: 0; margin-bottom: 0; -unity-text-align: upper-left; align-self: flex-start;"/>
                    <ui:Label text="Style Points" name="StylePointsLabel" style="position: absolute; width: 100%; height: 38px; -unity-text-align: middle-center; font-size: 34px; margin-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; align-content: center; color: rgb(255, 145, 90);"/>
                </ui:VisualElement>
                <ui:VisualElement name="StyleFeed" style="flex-grow: 1; position: relative; width: 100%; height: 100%; border-bottom-width: 5px; border-top-width: 5px; border-top-color: rgba(0, 0, 0, 0.39); border-bottom-color: rgba(0, 0, 0, 0.39); justify-content: flex-end;"/>
            </ui:VisualElement>
            <ui:Label text="1.0x NORMAL" name="FreshnessLabel" style="right: auto; position: relative; -unity-text-align: middle-center; font-size: 40px; color: rgb(255, 255, 255);"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
