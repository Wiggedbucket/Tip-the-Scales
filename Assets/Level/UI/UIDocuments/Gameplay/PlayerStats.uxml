<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Level/UI/StyleSheets/PlayerStats.uss?fileID=7433441132597879392&amp;guid=6455ac2e63ec0644d8ed5322ad7d0a97&amp;type=3#PlayerStats"/>
    <ui:VisualElement name="Aligner" style="flex-grow: 1; align-content: auto; justify-content: flex-end; height: auto; width: auto;">
        <ui:Label text="Ammo: 0/0" name="AmmoLabel" class="stat-label" style="bottom: auto; position: relative; top: auto; left: auto; right: auto; color: rgb(211, 211, 211);"/>
        <ui:VisualElement name="DashBar" style="flex-grow: 0; width: 300px; height: 69px; margin-left: 30px; margin-bottom: 0; margin-top: 10px; background-color: rgb(0, 44, 93); justify-content: center; align-self: auto; padding-left: 5px; padding-right: 5px; padding-top: 5px; padding-bottom: 5px; flex-direction: column; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
            <ui:VisualElement name="DashBarFill" style="flex-grow: 1; align-self: flex-start; height: 100%; width: 0%; position: relative; background-color: rgb(0, 78, 163); border-top-left-radius: 5px; border-bottom-left-radius: 5px; border-bottom-right-radius: 5px; border-top-right-radius: 5px;"/>
        </ui:VisualElement>
        <ui:VisualElement name="HealthBar" style="flex-grow: 0; width: 500px; height: 100px; margin-left: 30px; margin-bottom: 30px; margin-top: 10px; background-color: rgb(8, 93, 0); justify-content: center; align-self: auto; padding-left: 5px; padding-right: 5px; padding-top: 5px; padding-bottom: 5px; flex-direction: column; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
            <ui:VisualElement name="HealthBarFill" style="flex-grow: 1; align-self: flex-start; height: 100%; width: 100%; position: relative; background-color: rgb(17, 209, 0); justify-content: center; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                <ui:Label text="Health: 0/0" name="HealthLabel" class="stat-label" style="color: rgb(255, 255, 255); margin-left: 10px; margin-bottom: 0;"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement name="Aligner" style="flex-grow: 1; position: absolute; justify-content: center; width: 100%; height: 100%;">
        <ui:VisualElement name="Aligner" style="flex-grow: 1; position: absolute; left: auto; right: auto; top: auto; bottom: auto; align-self: center;">
            <ui:VisualElement name="Pointer" style="flex-grow: 1; border-top-width: 3px; border-left-width: 3px; border-bottom-width: 3px; border-right-width: 3px; border-top-color: rgba(255, 255, 255, 0.49); border-right-color: rgba(255, 255, 255, 0.49); border-bottom-color: rgba(255, 255, 255, 0.49); border-left-color: rgba(255, 255, 255, 0.49); width: 20px; height: 20px; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; justify-content: center; align-items: center;">
                <ui:VisualElement name="HitIndicator" class="hidden" style="flex-grow: 1; position: absolute; background-image: url(&quot;project://database/Assets/Art/Textures/Crosshair.png?fileID=2800000&amp;guid=987fc48c8aad14b4395c0557447c23f3&amp;type=3#Crosshair&quot;); width: 450%; height: 450%;"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
