:root {
}

.panel-background {
    flex-grow: 1;
    background-color: rgba(0, 0, 0, 0.59);
}

.window {
    flex-grow: 1;
    background-color: rgb(93, 93, 93);
    margin-left: 100px;
    margin-right: 100px;
    margin-top: 50px;
    margin-bottom: 50px;
    border-bottom-color: rgb(0, 0, 0);
    border-right-color: rgb(0, 0, 0);
    border-top-color: rgb(0, 0, 0);
    border-left-color: rgb(0, 0, 0);
    border-top-width: 5px;
    border-right-width: 5px;
    border-bottom-width: 5px;
    border-left-width: 5px;
}

.hidden {
    display: none;
}

.title {
    align-items: center;
    -unity-text-align: middle-center;
    font-size: 64px;
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
    margin-top: 5px;
    margin-bottom: 5px;
}

.row {
    flex-grow: 1;
    flex-direction: row;
    position: relative;
    background-color: rgba(166, 166, 166, 0.55);
    margin-left: 10px;
    margin-right: 10px;
    margin-bottom: 10px;
    margin-top: 10px;
}

.row-label {
    -unity-text-align: middle-center;
    font-size: 38px;
}

.name-label {
    -unity-text-align: middle-left;
    margin-left: 20px;
    -unity-font-style: bold;
}

.binding-button {
    font-size: 40px;
    width: auto;
    align-self: center;
    margin-bottom: 10px;
    margin-top: 10px;
}

.heading {
    align-items: center;
    -unity-text-align: middle-left;
    font-size: 52px;
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
    margin-top: 5px;
    margin-bottom: 5px;
}

.action-row {
    flex-wrap: nowrap;
    margin-left: 10px;
    margin-right: 10px;
    flex-grow: 1;
    border-top-width: 5px;
    border-bottom-width: 5px;
    border-left-width: 5px;
    border-right-width: 5px;
    border-top-color: rgb(0, 0, 0);
    border-left-color: rgb(0, 0, 0);
    border-right-color: rgb(0, 0, 0);
    border-bottom-color: rgb(0, 0, 0);
    justify-content: flex-start;
    align-items: stretch;
    align-content: flex-start;
    background-color: rgba(0, 0, 0, 0.39);
    flex-direction: column;
}

.heading-two {
    align-items: center;
    -unity-text-align: middle-left;
    font-size: 45px;
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
    margin-top: 5px;
    margin-bottom: 5px;
    flex-grow: 1;
    margin-right: 0;
    width: auto;
    margin-left: 0;
    padding-left: 45px;
}

.divider {
    flex-grow: 1;
    background-color: rgb(0, 0, 0);
    border-top-width: 5px;
    border-top-color: rgb(0, 0, 0);
    width: 97%;
    align-items: stretch;
    align-self: center;
}

.binding-buttons-container {
    margin-left: 0;
    margin-right: 0;
    flex-direction: row;
    flex-grow: 1;
    flex-wrap: wrap;
    margin-bottom: 0;
}

.binding-groups-container {
    width: 100%;
    margin-left: 0;
    margin-right: 0;
    padding-right: 50px;
    padding-left: 50px;
}

.binding-group {
    flex-grow: 1;
    flex-direction: column;
    width: 100%;
}

.heading-three {
    align-items: center;
    -unity-text-align: upper-left;
    font-size: 45px;
    color: rgb(255, 255, 255);
    -unity-font-style: normal;
    margin-top: 5px;
    margin-bottom: 5px;
    flex-grow: 1;
    margin-right: 0;
    width: auto;
    margin-left: 0;
    padding-left: 10px;
}

.binding-button-bundle {
    flex-direction: row;
    align-items: center;
    width: 100%;
    margin-left: 0;
    padding-left: 40px;
    padding-right: 40px;
    border-top-width: 5px;
    border-bottom-width: 5px;
    border-bottom-color: rgba(0, 0, 0, 0.51);
    border-top-color: rgba(0, 0, 0, 0.51);
}



.binding-part-label {
    min-width: 100px;
    color: rgb(255, 255, 255);
    font-size: 36px;
    -unity-text-align: middle-left;
}

.reset-binding-button {
    font-size: 40px;
    align-self: flex-end;
    margin-bottom: 10px;
    margin-top: 10px;
    margin-left: auto;
}
